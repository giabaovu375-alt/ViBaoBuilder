import { useEffect, useMemo, useState } from "react";
import { Link, useNavigate } from "@tanstack/react-router";
import {
  createProject,
  deleteProject,
  renameProject,
  useStore,
  type TemplateKey,
} from "@/lib/builder/store";

/* ============================================================
 * ViBaoBuilder — Dashboard
 * No-code visual editor (canvas + toạ độ, không phải kéo–thả tự do).
 * Single-file, production-grade, fully responsive, SPA navigation.
 * ============================================================ */

const T = {
  navy: "#0A2463",
  navyDeep: "#071a4a",
  navySoft: "#1a3a8a",
  gold: "#F5C518",
  bg: "#f5f7fb",
  surface: "#ffffff",
  border: "#e0e8f4",
  borderSoft: "#eef2f9",
  muted: "#7a90b0",
  chip: "#e8eef8",
  danger: "#cc0022",
  dangerSoft: "#fff0f0",
  font: "'Inter', system-ui, -apple-system, Segoe UI, Roboto, sans-serif",
};

const TEMPLATES: { id: TemplateKey; name: string; tag: string; desc: string; emoji: string; bg: string }[] = [
  { id: "landing", name: "Landing Page", tag: "Phổ biến", desc: "Giới thiệu sản phẩm.", emoji: "🚀", bg: "linear-gradient(135deg,#e8f4ff,#c5deff)" },
  { id: "portfolio", name: "Portfolio", tag: "Sáng tạo", desc: "Showcase cá nhân.", emoji: "🎨", bg: "linear-gradient(135deg,#fff8e0,#ffe88a)" },
  { id: "shop", name: "Cửa hàng", tag: "Kinh doanh", desc: "Trưng bày sản phẩm.", emoji: "🛍️", bg: "linear-gradient(135deg,#e8fff4,#a8f0d0)" },
  { id: "event", name: "Sự kiện", tag: "Mới", desc: "Trang đăng ký sự kiện.", emoji: "🎟️", bg: "linear-gradient(135deg,#fde8ff,#f0bfff)" },
];

/* ---------- Page ---------- */
export function DashboardPage() {
  const projects = useStore((s) => s.projects);
  const navigate = useNavigate();
  const [name, setName] = useState("");
  const [menuOpen, setMenuOpen] = useState(false);
  const [query, setQuery] = useState("");

  // SPA navigation — không reload, không delay
  function goEditor(id: string) {
    void navigate({ to: "/editor/$projectId", params: { projectId: id } });
  }

  function handleCreate(e: React.FormEvent) {
    e.preventDefault();
    const p = createProject(name.trim() || "Dự án mới", "blank");
    setName("");
    goEditor(p.id);
  }

  function handleTemplate(tpl: { id: TemplateKey; name: string }) {
    const p = createProject(tpl.name, tpl.id);
    goEditor(p.id);
  }

  // Khoá scroll khi mở menu mobile
  useEffect(() => {
    if (typeof document === "undefined") return;
    document.body.style.overflow = menuOpen ? "hidden" : "";
    return () => {
      document.body.style.overflow = "";
    };
  }, [menuOpen]);

  const filtered = useMemo(() => {
    const q = query.trim().toLowerCase();
    if (!q) return projects;
    return projects.filter((p) => p.name.toLowerCase().includes(q));
  }, [projects, query]);

  return (
    <div style={{ minHeight: "100vh", background: T.bg, fontFamily: T.font, color: T.navy }}>
      <GlobalStyles />

      {/* ===================== NAV ===================== */}
      <header className="vb-nav">
        <div className="vb-nav-inner">
          <Link to="/" className="vb-brand" aria-label="ViBaoBuilder">
            <span className="vb-brand-mark">ViBao</span>
            <span className="vb-brand-sub">Builder</span>
          </Link>

          <nav className="vb-nav-links" aria-label="Chính">
            <NavLink href="#templates">Mẫu</NavLink>
            <NavLink href="#projects">Dự án</NavLink>
            <NavLink href="#">Hướng dẫn</NavLink>
            <NavLink href="#">Cộng đồng</NavLink>
          </nav>

          <button
            type="button"
            className="vb-burger"
            aria-label={menuOpen ? "Đóng menu" : "Mở menu"}
            aria-expanded={menuOpen}
            aria-controls="vb-mobile-menu"
            onClick={() => setMenuOpen((v) => !v)}
          >
            <span data-open={menuOpen} />
            <span data-open={menuOpen} />
            <span data-open={menuOpen} />
          </button>
        </div>

        {/* Mobile menu */}
        <div
          id="vb-mobile-menu"
          className="vb-mobile-menu"
          data-open={menuOpen}
          role="menu"
        >
          <a href="#templates" role="menuitem" onClick={() => setMenuOpen(false)}>Mẫu</a>
          <a href="#projects" role="menuitem" onClick={() => setMenuOpen(false)}>Dự án</a>
          <a href="#" role="menuitem" onClick={() => setMenuOpen(false)}>Hướng dẫn</a>
          <a href="#" role="menuitem" onClick={() => setMenuOpen(false)}>Cộng đồng</a>
        </div>
      </header>

      {/* ===================== HERO ===================== */}
      <section className="vb-hero">
        <div className="vb-hero-inner">
          <span className="vb-pill">No-code · Miễn phí</span>
          <h1 className="vb-h1">
            Thiết kế website <span style={{ color: T.gold }}>theo cách của bạn</span>
          </h1>
          <p className="vb-sub">
            Sắp xếp bố cục bằng toạ độ chính xác. Tuỳ chỉnh từng pixel — xuất bản trong vài giây.
          </p>

          <form onSubmit={handleCreate} className="vb-create">
            <input
              value={name}
              onChange={(e) => setName(e.target.value)}
              placeholder="Tên dự án mới…"
              aria-label="Tên dự án"
              className="vb-input"
            />
            <button type="submit" className="vb-btn-primary">+ Tạo mới</button>
          </form>
        </div>
      </section>

      {/* ===================== TEMPLATES ===================== */}
      <main className="vb-container">
        <section id="templates" className="vb-section">
          <SectionTitle bar={T.gold} title="Mẫu nổi bật" hint="Bắt đầu nhanh với mẫu sẵn có" />
          <div className="vb-grid">
            {TEMPLATES.map((t) => (
              <article key={t.id} className="vb-card">
                <div className="vb-card-cover" style={{ background: t.bg }}>{t.emoji}</div>
                <div className="vb-card-body">
                  <span className="vb-tag">{t.tag}</span>
                  <h3 className="vb-card-title">{t.name}</h3>
                  <p className="vb-card-desc">{t.desc}</p>
                  <button type="button" className="vb-btn-primary vb-btn-block" onClick={() => handleTemplate(t)}>
                    Dùng mẫu
                  </button>
                </div>
              </article>
            ))}
          </div>
        </section>

        {/* ===================== PROJECTS ===================== */}
        <section id="projects" className="vb-section">
          <div className="vb-section-head">
            <SectionTitle
              bar={T.navy}
              title="Dự án của bạn"
              count={projects.length}
            />
            {projects.length > 0 && (
              <input
                value={query}
                onChange={(e) => setQuery(e.target.value)}
                placeholder="Tìm dự án…"
                aria-label="Tìm dự án"
                className="vb-search"
              />
            )}
          </div>

          {projects.length === 0 ? (
            <div className="vb-empty">
              <div className="vb-empty-icon">🗂️</div>
              <p className="vb-empty-title">Chưa có dự án nào</p>
              <p className="vb-empty-desc">Tạo dự án mới ở trên hoặc chọn một mẫu để bắt đầu.</p>
            </div>
          ) : filtered.length === 0 ? (
            <div className="vb-empty">
              <p className="vb-empty-desc">Không tìm thấy dự án nào khớp “{query}”.</p>
            </div>
          ) : (
            <div className="vb-grid">
              {filtered.map((p) => (
                <article key={p.id} className="vb-card">
                  <div
                    className="vb-card-cover"
                    style={{ background: "linear-gradient(135deg,#e8eef8,#c5d3e8)", cursor: "pointer" }}
                    onClick={() => goEditor(p.id)}
                  >
                    🌐
                  </div>
                  <div className="vb-card-body">
                    <input
                      defaultValue={p.name}
                      onBlur={(e) => renameProject(p.id, e.target.value.trim() || p.name)}
                      onKeyDown={(e) => { if (e.key === "Enter") (e.target as HTMLInputElement).blur(); }}
                      aria-label="Đổi tên dự án"
                      className="vb-rename"
                    />
                    <p className="vb-meta">
                      {p.slides.length} trang · {new Date(p.updatedAt).toLocaleDateString("vi-VN")}
                    </p>
                    <div className="vb-actions">
                      <Link
                        to="/editor/$projectId"
                        params={{ projectId: p.id }}
                        className="vb-btn-primary vb-btn-sm"
                        style={{ background: T.navy, color: "#fff" }}
                      >
                        Sửa
                      </Link>
                      <Link
                        to="/export/$projectId"
                        params={{ projectId: p.id }}
                        className="vb-btn-ghost vb-btn-sm"
                      >
                        Xuất
                      </Link>
                      <button
                        type="button"
                        className="vb-btn-danger vb-btn-sm"
                        aria-label={`Xoá ${p.name}`}
                        onClick={() => { if (confirm(`Xoá "${p.name}"?`)) deleteProject(p.id); }}
                      >
                        🗑
                      </button>
                    </div>
                  </div>
                </article>
              ))}
            </div>
          )}
        </section>
      </main>

      {/* ===================== FOOTER ===================== */}
      <footer className="vb-footer">
        <div className="vb-container">
          <div className="vb-footer-grid">
            <div>
              <p className="vb-footer-brand">ViBaoBuilder</p>
              <p className="vb-footer-desc">Công cụ tạo website no-code dành cho người Việt.</p>
            </div>
            <FooterCol title="Sản phẩm" links={["Tính năng", "Mẫu thiết kế", "Bảng giá", "Changelog"]} />
            <FooterCol title="Hỗ trợ" links={["Hướng dẫn", "FAQ", "Cộng đồng", "Liên hệ"]} />
            <FooterCol title="Pháp lý" links={["Điều khoản", "Bảo mật", "Cookie", "Về chúng tôi"]} />
          </div>
          <div className="vb-footer-bottom">
            <span>© {new Date().getFullYear()} ViBaoBuilder</span>
            <span style={{ color: T.gold, fontWeight: 600 }}>Made with ❤️ in Vietnam 🇻🇳</span>
          </div>
        </div>
      </footer>
    </div>
  );
}

/* ---------- Small components ---------- */
function NavLink({ href, children }: { href: string; children: React.ReactNode }) {
  return <a href={href} className="vb-navlink">{children}</a>;
}

function SectionTitle({
  title,
  bar,
  count,
  hint,
}: {
  title: string;
  bar: string;
  count?: number;
  hint?: string;
}) {
  return (
    <div className="vb-title">
      <span className="vb-title-bar" style={{ background: bar }} />
      <h2 className="vb-title-text">
        {title}
        {typeof count === "number" && count > 0 && <span className="vb-title-count">{count}</span>}
      </h2>
      {hint && <span className="vb-title-hint">{hint}</span>}
    </div>
  );
}

function FooterCol({ title, links }: { title: string; links: string[] }) {
  return (
    <div>
      <p className="vb-footer-col-title">{title}</p>
      <ul className="vb-footer-col-list">
        {links.map((l) => (
          <li key={l}><a href="#">{l}</a></li>
        ))}
      </ul>
    </div>
  );
}

/* ---------- Styles ---------- */
function GlobalStyles() {
  return (
    <style>{`
      * { box-sizing: border-box; }
      a { color: inherit; }
      .vb-container { max-width: 1100px; margin: 0 auto; padding: 0 16px; }

      /* NAV */
      .vb-nav { position: sticky; top: 0; z-index: 50; background: ${T.navy}; border-bottom: 2px solid ${T.gold}; }
      .vb-nav-inner { max-width: 1100px; margin: 0 auto; padding: 0 16px; height: 56px; display: flex; align-items: center; justify-content: space-between; gap: 16px; }
      .vb-brand { display: inline-flex; align-items: baseline; gap: 6px; text-decoration: none; }
      .vb-brand-mark { color: ${T.gold}; font-size: 18px; font-weight: 800; letter-spacing: -0.3px; }
      .vb-brand-sub { color: #fff; font-size: 18px; font-weight: 300; }
      .vb-nav-links { display: none; gap: 28px; align-items: center; }
      .vb-navlink { color: rgba(255,255,255,0.72); font-size: 13px; font-weight: 500; text-decoration: none; transition: color .15s; }
      .vb-navlink:hover { color: ${T.gold}; }
      .vb-burger { background: none; border: none; cursor: pointer; padding: 8px; display: inline-flex; flex-direction: column; gap: 5px; }
      .vb-burger span { width: 22px; height: 2px; background: ${T.gold}; border-radius: 2px; display: block; transition: transform .2s, opacity .2s; transform-origin: center; }
      .vb-burger span[data-open="true"]:nth-child(1) { transform: rotate(45deg) translate(5px,5px); }
      .vb-burger span[data-open="true"]:nth-child(2) { opacity: 0; }
      .vb-burger span[data-open="true"]:nth-child(3) { transform: rotate(-45deg) translate(5px,-5px); }
      .vb-mobile-menu { display: flex; flex-direction: column; gap: 4px; padding: 8px 16px 16px; background: ${T.navyDeep}; border-top: 1px solid rgba(255,255,255,0.08); max-height: 0; overflow: hidden; transition: max-height .25s ease, padding .25s ease; }
      .vb-mobile-menu[data-open="true"] { max-height: 260px; }
      .vb-mobile-menu a { color: rgba(255,255,255,0.85); text-decoration: none; padding: 12px 8px; border-radius: 8px; font-size: 15px; }
      .vb-mobile-menu a:active { background: rgba(255,255,255,0.06); }

      /* HERO */
      .vb-hero { background: linear-gradient(135deg, ${T.navy} 0%, ${T.navySoft} 100%); padding: 56px 16px 48px; }
      .vb-hero-inner { max-width: 560px; margin: 0 auto; text-align: center; }
      .vb-pill { display: inline-block; background: ${T.gold}; color: ${T.navy}; font-weight: 700; font-size: 10px; letter-spacing: 2px; padding: 4px 12px; border-radius: 999px; text-transform: uppercase; margin-bottom: 16px; }
      .vb-h1 { color: #fff; font-size: clamp(26px, 6vw, 44px); font-weight: 800; line-height: 1.15; margin: 0 0 12px; letter-spacing: -0.5px; }
      .vb-sub { color: rgba(255,255,255,0.7); font-size: 14px; line-height: 1.55; margin: 0 0 24px; }
      .vb-create { display: flex; gap: 8px; }
      .vb-input { flex: 1; min-width: 0; background: rgba(255,255,255,0.13); border: 1.5px solid rgba(255,255,255,0.22); border-radius: 10px; padding: 12px 14px; color: #fff; font-size: 14px; outline: none; transition: border-color .15s, background .15s; }
      .vb-input::placeholder { color: rgba(255,255,255,0.5); }
      .vb-input:focus { border-color: ${T.gold}; background: rgba(255,255,255,0.18); }

      /* BUTTONS */
      .vb-btn-primary { background: ${T.gold}; color: ${T.navy}; font-weight: 700; font-size: 13px; border: none; border-radius: 10px; padding: 11px 18px; cursor: pointer; white-space: nowrap; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; transition: transform .08s, filter .15s; }
      .vb-btn-primary:hover { filter: brightness(1.05); }
      .vb-btn-primary:active { transform: translateY(1px); }
      .vb-btn-block { width: 100%; }
      .vb-btn-sm { padding: 8px 10px; font-size: 12px; border-radius: 8px; flex: 1; }
      .vb-btn-ghost { background: ${T.borderSoft}; color: ${T.navy}; font-weight: 600; border: none; cursor: pointer; text-decoration: none; display: inline-flex; align-items: center; justify-content: center; transition: background .15s; }
      .vb-btn-ghost:hover { background: ${T.chip}; }
      .vb-btn-danger { background: ${T.dangerSoft}; color: ${T.danger}; font-weight: 600; border: none; cursor: pointer; flex: 0 0 auto !important; padding: 8px 12px !important; }
      .vb-btn-danger:hover { background: #ffe0e3; }

      /* SECTIONS */
      .vb-section { padding: 32px 0; }
      .vb-section + .vb-section { border-top: 1.5px solid ${T.border}; }
      .vb-section-head { display: flex; align-items: center; justify-content: space-between; gap: 12px; flex-wrap: wrap; margin-bottom: 4px; }
      .vb-search { background: #fff; border: 1.5px solid ${T.border}; border-radius: 10px; padding: 9px 13px; font-size: 13px; color: ${T.navy}; outline: none; min-width: 0; flex: 1 1 200px; max-width: 280px; transition: border-color .15s; }
      .vb-search:focus { border-color: ${T.navy}; }

      .vb-title { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
      .vb-title-bar { width: 4px; height: 20px; border-radius: 2px; flex-shrink: 0; }
      .vb-title-text { color: ${T.navy}; font-weight: 700; font-size: 16px; margin: 0; display: inline-flex; align-items: center; gap: 8px; }
      .vb-title-count { background: ${T.chip}; color: ${T.navy}; font-size: 11px; font-weight: 700; padding: 2px 8px; border-radius: 999px; }
      .vb-title-hint { color: ${T.muted}; font-size: 12px; }

      /* GRID + CARDS */
      .vb-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(170px, 1fr)); gap: 14px; margin-top: 16px; }
      .vb-card { border: 1.5px solid ${T.border}; border-radius: 14px; overflow: hidden; background: ${T.surface}; transition: box-shadow .15s, transform .15s, border-color .15s; display: flex; flex-direction: column; }
      .vb-card:hover { box-shadow: 0 6px 20px rgba(10,36,99,0.10); border-color: #cfdcef; }
      .vb-card-cover { height: 86px; display: flex; align-items: center; justify-content: center; font-size: 30px; user-select: none; }
      .vb-card-body { padding: 12px; display: flex; flex-direction: column; gap: 6px; }
      .vb-tag { align-self: flex-start; background: ${T.chip}; color: ${T.navy}; font-size: 9px; font-weight: 700; padding: 3px 8px; border-radius: 999px; text-transform: uppercase; letter-spacing: 0.5px; }
      .vb-card-title { font-weight: 700; font-size: 14px; color: ${T.navy}; margin: 2px 0 0; }
      .vb-card-desc { color: ${T.muted}; font-size: 12px; margin: 0 0 8px; line-height: 1.4; }
      .vb-rename { background: transparent; border: 1px solid transparent; outline: none; font-weight: 700; font-size: 14px; color: ${T.navy}; width: 100%; padding: 4px 6px; margin: -4px -6px 0; border-radius: 6px; font-family: inherit; transition: background .15s, border-color .15s; }
      .vb-rename:hover { background: ${T.borderSoft}; }
      .vb-rename:focus { background: #fff; border-color: ${T.navy}; }
      .vb-meta { color: ${T.muted}; font-size: 11px; margin: 2px 0 10px; }
      .vb-actions { display: flex; gap: 6px; }

      /* EMPTY */
      .vb-empty { border: 2px dashed #c5d3e8; border-radius: 14px; padding: 40px 16px; text-align: center; margin-top: 16px; background: #fafcff; }
      .vb-empty-icon { font-size: 36px; margin-bottom: 8px; }
      .vb-empty-title { color: ${T.navy}; font-weight: 700; font-size: 15px; margin: 0 0 4px; }
      .vb-empty-desc { color: ${T.muted}; font-size: 13px; margin: 0; }

      /* FOOTER */
      .vb-footer { background: ${T.navy}; border-top: 2px solid ${T.gold}; margin-top: 24px; }
      .vb-footer > .vb-container { padding-top: 32px; padding-bottom: 24px; }
      .vb-footer-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(160px, 1fr)); gap: 24px; margin-bottom: 24px; }
      .vb-footer-brand { color: ${T.gold}; font-weight: 700; font-size: 15px; margin: 0 0 8px; }
      .vb-footer-desc { color: rgba(255,255,255,0.5); font-size: 12px; line-height: 1.6; margin: 0; }
      .vb-footer-col-title { color: rgba(255,255,255,0.65); font-weight: 600; font-size: 11px; margin: 0 0 10px; text-transform: uppercase; letter-spacing: 0.6px; }
      .vb-footer-col-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 8px; }
      .vb-footer-col-list a { color: rgba(255,255,255,0.45); font-size: 12px; text-decoration: none; transition: color .15s; }
      .vb-footer-col-list a:hover { color: ${T.gold}; }
      .vb-footer-bottom { border-top: 1px solid rgba(255,255,255,0.1); padding-top: 16px; display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: 8px; color: rgba(255,255,255,0.4); font-size: 11px; }

      /* Responsive */
      @media (min-width: 720px) {
        .vb-nav-links { display: flex; }
        .vb-burger { display: none; }
        .vb-mobile-menu { display: none; }
        .vb-grid { grid-template-columns: repeat(auto-fill, minmax(200px, 1fr)); gap: 16px; }
        .vb-hero { padding: 72px 16px 64px; }
      }
      @media (max-width: 480px) {
        .vb-grid { grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 10px; }
        .vb-card-cover { height: 76px; font-size: 26px; }
        .vb-card-body { padding: 10px; }
        .vb-section { padding: 24px 0; }
        .vb-hero { padding: 40px 16px 36px; }
      }
    `}</style>
  );
}
 